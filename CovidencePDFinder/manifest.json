{
  "manifest_version": 3,
  "name": "Covidence PDF Finder",
  "version": "1.1.8.5",
  "description": "Search open-access PDFs from Covidence, use Google Scholar fallback, OpenAlex, and custom database DOI/title search with JSTOR institutional proxy support.",
  "permissions": [
    "downloads",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}